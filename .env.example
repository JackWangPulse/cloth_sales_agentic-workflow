APP_NAME=Cloth Sales Service
APP_VERSION=5.3.0
APP_ENV=prod
DEBUG=false

# Application
APP_PORT=18000
LOG_LEVEL=info
LOG_DIR=logs
LOG_BACKUP_COUNT=14

# Database
# Local or external database:
# DATABASE_URL=mysql+pymysql://username:password@host.docker.internal:3306/cloth_sales?charset=utf8mb4
# Docker Compose database:
DATABASE_URL=mysql+pymysql://cloth_user:cloth_password@mysql:3306/cloth_sales?charset=utf8mb4
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=cloth_sales
MYSQL_USER=cloth_user
MYSQL_PASSWORD=cloth_password
MYSQL_PORT=3307

# Redis
# Local or external Redis:
# REDIS_URL=redis://host.docker.internal:6379/0
# Docker Compose Redis:
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=cloth-sales
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# LLM
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Embedding
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v2

# Vision
VISION_MODEL=qwen-vl-max
VISION_API_KEY=your_vision_api_key_here
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
USE_MOCK_VISION=false

# Intent engine
INTENT_MIN_STAY_FOR_HIGH=60
INTENT_MIN_VISITS_FOR_HIGH_WITH_FAVORITE=2
INTENT_MIN_VISITS_FOR_HESITATING=3
INTENT_MIN_STAY_FOR_HESITATING=20
INTENT_MIN_VISITS_FOR_MEDIUM=2
INTENT_MIN_STAY_FOR_MEDIUM=15
INTENT_MAX_STAY_FOR_LOW=10

# Copy generation
COPY_MAX_LENGTH=45
